# Copy this file to .env for local runs.
# Do not commit real tokens or credentials.

# Hugging Face
HF_TOKEN=
HF_MODEL_REPO_ID=thanhhoangnvbg/fire-vn-yolo11x-detect-fire-smoke-a100-final
HF_PRIVATE_MODEL=0

# Dataset/model repos
DATASET_REPO_ID=thanhhoangnvbg/fire-vn-yolo11seg-v1
DATASET_ZIP_NAME=fire_vn_yolo11seg_v1.zip

# Vertex/GCS training outputs
GCS_DIR=gs://fire_detection_final/yolo11x_detect_fire_smoke_a100_final
FINETUNE_GCS_DIR=gs://fire_detection_final/yolo11x_detect_fire_smoke_a100_finetune

# Training profile
PROFILE=vertex_detect_a100
FINETUNE_PROFILE=vertex_detect_finetune_a100
RUN_FINETUNE=1
IMG_SIZE=1280
BATCH=4
FINETUNE_BATCH=4
TEST_IMG_SIZE=1280
VAL_TTA=1

# Resume/skip controls
SKIP_DOWNLOAD=0
SKIP_CONVERT=0
RESTORE_FROM_GCS=0
FINETUNE_RESTORE_FROM_GCS=0
